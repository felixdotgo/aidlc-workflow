{
  "title": "AI-DLC managed installation manifest",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "packageVersion", "workflow", "source", "remoteUpdates", "managedBy", "adapters", "files"],
  "properties": {
    "schemaVersion": { "const": 2 }, "packageVersion": { "type": "string" }, "workflow": { "const": "AI-DLC" },
    "source": { "const": "local-package-assets" }, "remoteUpdates": { "const": false }, "managedBy": { "const": "aidlc-workflow" },
    "adapters": { "type": "array", "items": { "enum": ["claude", "codex", "cursor", "antigravity", "kiro", "generic"] } },
    "files": { "type": "object", "additionalProperties": { "type": "object", "required": ["hash", "owner", "strategy"], "properties": { "hash": { "type": "string" }, "owner": { "type": "string" }, "strategy": { "enum": ["replace", "managed-block"] } } } }
  }
}

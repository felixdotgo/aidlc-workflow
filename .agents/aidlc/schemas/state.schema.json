{
  "title": "AI-DLC canonical state",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "tasks"],
  "properties": {
    "schemaVersion": { "const": 1 },
    "tasks": { "type": "object", "additionalProperties": { "$ref": "#/$defs/task" } }
  },
  "$defs": {
    "task": {
      "type": "object",
      "required": ["id", "title", "type", "phase", "gate", "status", "language", "risk", "areas", "branch", "artifacts", "decisions", "tasks", "evidence", "createdAt", "updatedAt"],
      "properties": {
        "id": { "type": "string" }, "title": { "type": "string" },
        "type": { "enum": ["feature", "bug", "refactor", "infra"] },
        "phase": { "enum": ["clarify", "plan", "build", "wrap", "done"] },
        "gate": { "enum": ["none", "G0_confirm", "G1_review", "G2_codereview"] },
        "status": { "enum": ["active", "blocked_on_user", "paused", "done"] },
        "language": { "enum": ["vi", "en"] }, "risk": { "enum": ["low", "normal", "high", "regulated"] },
        "areas": { "type": "array", "minItems": 1, "items": { "type": "string" } }, "branch": { "type": "string" },
        "artifacts": { "type": "object" },
        "decisions": { "type": "array", "items": { "$ref": "#/$defs/decision" } },
        "tasks": { "type": "array", "items": { "$ref": "#/$defs/executionTask" } },
        "evidence": { "type": "array", "items": { "$ref": "#/$defs/evidence" } },
        "createdAt": { "type": "string" }, "updatedAt": { "type": "string" }
      }
    },
    "decision": { "type": "object", "required": ["id", "label", "status"], "properties": { "id": { "type": "string" }, "label": { "type": "string" }, "status": { "enum": ["unresolved", "approved", "changed", "dropped"] }, "resolution": { "type": "string" } } },
    "executionTask": { "type": "object", "required": ["id", "label", "status"], "properties": { "id": { "type": "string" }, "label": { "type": "string" }, "status": { "enum": ["todo", "in_progress", "done", "deferred"] } } },
    "evidence": { "type": "object", "required": ["kind", "source", "result", "recordedAt"], "properties": { "kind": { "enum": ["approval", "spec", "test", "lint", "review", "diagnostic"] }, "gate": { "enum": ["none", "G0_confirm", "G1_review", "G2_codereview"] }, "area": { "type": "string" }, "source": { "type": "string" }, "result": { "enum": ["pass", "fail", "skip"] }, "detail": { "type": "string" }, "recordedAt": { "type": "string" } } }
  }
}
